# CRA default reproduction image.
# Prefer the target repository's official Dockerfile or image when available.
# Edit this file in the task workspace to match the repository requirements.

FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        curl \
        git \
        build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace/source

# Add durable dependency installation here when the target repository requires it.
# Examples:
# COPY source/requirements.txt /tmp/requirements.txt
# RUN python -m pip install --no-cache-dir -r /tmp/requirements.txt
# RUN python -m pip install --no-cache-dir -e /workspace/source

CMD ["sleep", "infinity"]
